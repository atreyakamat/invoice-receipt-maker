{
  "name": "invoice-receipt-maker-server",
  "version": "1.0.0",
  "description": "Backend API for AI Invoice & Receipt Intake Assistant",
  "main": "dist/app.js",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "argon2": "^0.40.1",
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.0-beta.1",
    "googleapis": "^173.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "openai": "^6.45.0",
    "stripe": "^22.3.0",
    "tesseract.js": "^5.1.1",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "prisma": "^6.0.0",
    "supertest": "^6.3.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  }
}
