# ==========================================
# Invoice & Receipt Maker - Environment Configuration
# ==========================================

# 1. Database Configuration (PostgreSQL)
# Used by Prisma ORM. Update credentials to match your docker-compose or managed DB.
DATABASE_URL="postgresql://admin:adminpassword@localhost:5432/invoice_db?schema=public"

# 2. Redis Configuration (BullMQ Background Jobs)
# Used by the OCR and notification worker queues.
REDIS_URL="redis://localhost:6379"

# 3. Server Configuration
PORT=3000
NODE_ENV="development"
CLIENT_URL="http://localhost:5173"

# 4. Authentication Secrets
# Generate a strong 64-character hex string for production
JWT_SECRET="super-secret-jwt-key-replace-in-production"

# 5. AI & External Services
# The API key required for Nvidia AI services (LLM, Vision, OCR)
NVIDIA_API_KEY="your-nvidia-api-key-here"

# 6. Payment Processing (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."

# 7. Email Dispatch (SendGrid or standard SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-smtp-password"
FROM_EMAIL="noreply@yourdomain.com"
